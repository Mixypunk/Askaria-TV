<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config pour Askaria TV
    - HTTPS uniquement pour tout le trafic (cleartextTrafficPermitted=false)
    - Trust system CAs (Let's Encrypt inclus via ISRG Root X1)
    - Pas d'exceptions cleartext → forçage SSL/TLS
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Autorités de certification système (inclut Let's Encrypt/ISRG) -->
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
